    "@mui/material": "^5.15.15",
    "@mui/x-date-pickers": "^7.2.0",
    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.6.8",
    "date-fns": "^3.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
